// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(ORGANIZER)
  createdAt    DateTime @default(now()) @map("created_at")
  
  events       Event[]
  reviews      Review[]
  
  @@map("users")
}

enum UserRole {
  ADMIN
  ORGANIZER
}

enum EventType {
  TICKETED
  RSVP
}

model Event {
  id          String    @id @default(uuid())
  organizerId String    @map("organizer_id")
  title       String
  slug        String    @unique
  description String    @db.Text
  location    String
  startTime   DateTime  @map("start_time")
  endTime     DateTime  @map("end_time")
  capacity    Int       
  priceCents  Int       @default(0) @map("price_cents")
  currency    String    @default("INR")
  type        EventType @default(TICKETED)
  posterUrl   String?   @map("poster_url")
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  organizer      User            @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  form           Form?
  registrations  Registration[]
  waitlist       Waitlist[]
  discounts      DiscountCode[]
  reviews        Review[]
  
  @@map("events")
}

model Form {
  id         String   @id @default(uuid())
  eventId    String   @unique @map("event_id")
  schemaJson Json     @map("schema_json")
  createdAt  DateTime @default(now()) @map("created_at")
  
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@map("forms")
}

model Registration {
  id           String             @id @default(uuid())
  eventId      String             @map("event_id")
  userEmail    String             @map("user_email")
  formResponse Json               @map("form_response")
  status       RegistrationStatus @default(PENDING)
  createdAt    DateTime           @default(now()) @map("created_at")
  
  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders Order[]
  
  @@map("registrations")
}

enum RegistrationStatus {
  PENDING
  PAID
  CONFIRMED
  CANCELLED
}

model Order {
  id              String       @id @default(uuid())
  registrationId  String       @map("registration_id")
  amountCents     Int          @map("amount_cents")
  currency        String       @default("INR")
  provider        PaymentProvider
  providerOrderId String?      @map("provider_order_id")
  status          OrderStatus  @default(CREATED)
  paymentData     Json?        @map("payment_data")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  ticket       Ticket?
  
  discountCodeId String?       @map("discount_code_id")
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id])
  
  @@map("orders")
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

enum OrderStatus {
  CREATED
  PAID
  FAILED
}

model Ticket {
  id           String    @id @default(uuid())
  orderId      String    @unique @map("order_id")
  qrPayload    String    @map("qr_payload") @db.Text
  ticketPdfUrl String?   @map("ticket_pdf_url")
  issuedAt     DateTime  @default(now()) @map("issued_at")
  revoked      Boolean   @default(false)
  validUntil   DateTime? @map("valid_until")
  scannedAt    DateTime? @map("scanned_at")
  
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@map("tickets")
}

model Waitlist {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  email     String
  name      String
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("waitlists")
  @@index([eventId, email])
}

model DiscountCode {
  id          String       @id @default(uuid())
  eventId     String       @map("event_id")
  code        String
  type        DiscountType @default(PERCENTAGE)
  amount      Int          // Percentage (e.g. 10 for 10%) or Amount in cents
  maxUses     Int?         @map("max_uses")
  usedCount   Int          @default(0) @map("used_count")
  validFrom   DateTime?    @map("valid_from")
  validUntil  DateTime?    @map("valid_until")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([eventId, code])
  @@map("discount_codes")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Review {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  userId      String   @map("user_id")
  rating      Int      // 1-5
  comment     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId]) // One review per user per event
  @@map("reviews")
}
