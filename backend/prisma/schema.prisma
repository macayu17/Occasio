// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(ORGANIZER)
  createdAt    DateTime @default(now()) @map("created_at")
  
  events       Event[]
  reviews      Review[]
  
  @@map("users")
}

enum UserRole {
  ADMIN
  ORGANIZER
}

enum EventType {
  TICKETED
  RSVP
}

enum EventCategory {
  MUSIC
  TECH
  SPORTS
  ARTS
  BUSINESS
  EDUCATION
  FOOD
  HEALTH
  SOCIAL
  OTHER
}

model Event {
  id          String        @id @default(uuid())
  organizerId String        @map("organizer_id")
  title       String
  slug        String        @unique
  description String        @db.Text
  location    String
  startTime   DateTime      @map("start_time")
  endTime     DateTime      @map("end_time")
  capacity    Int       
  priceCents  Int           @default(0) @map("price_cents")
  currency    String        @default("INR")
  type        EventType     @default(TICKETED)
  category    EventCategory @default(OTHER)
  tags        String[]      @default([])
  posterUrl   String?       @map("poster_url")
  published   Boolean       @default(false)
  
  // Ticket styling options (JSON: template, primaryColor, accentColor, logoUrl)
  ticketStyle Json?         @map("ticket_style")

  // Certificate styling
  certificateEnabled      Boolean   @default(false) @map("certificate_enabled")
  certificateTemplateUrl  String?   @map("certificate_template_url")
  certificateMapping      Json?     @map("certificate_mapping")
  
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  
  organizer      User            @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  form           Form?
  registrations  Registration[]
  waitlist       Waitlist[]
  discounts      DiscountCode[]
  reviews        Review[]
  polls          Poll[]
  teamMembers    TeamMember[]
  ticketTiers    TicketTier[]
  speakers       Speaker[]
  reminders      EventReminder[]
  
  @@map("events")
}

model Form {
  id         String   @id @default(uuid())
  eventId    String   @unique @map("event_id")
  schemaJson Json     @map("schema_json")
  createdAt  DateTime @default(now()) @map("created_at")
  
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@map("forms")
}

model Registration {
  id           String             @id @default(uuid())
  eventId      String             @map("event_id")
  userEmail    String             @map("user_email")
  formResponse Json               @map("form_response")
  status       RegistrationStatus @default(PENDING)
  createdAt    DateTime           @default(now()) @map("created_at")
  
  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders Order[]
  
  @@map("registrations")
}

enum RegistrationStatus {
  PENDING
  PAID
  CONFIRMED
  CANCELLED
}

model Order {
  id              String       @id @default(uuid())
  registrationId  String       @map("registration_id")
  amountCents     Int          @map("amount_cents")
  currency        String       @default("INR")
  provider        PaymentProvider
  providerOrderId String?      @map("provider_order_id")
  status          OrderStatus  @default(CREATED)
  paymentData     Json?        @map("payment_data")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  ticket       Ticket?
  
  discountCodeId String?       @map("discount_code_id")
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id])
  
  @@map("orders")
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
  PHONEPE
}

enum OrderStatus {
  CREATED
  PAID
  FAILED
}

model Ticket {
  id           String    @id @default(uuid())
  orderId      String    @unique @map("order_id")
  qrPayload    String    @map("qr_payload") @db.Text
  ticketPdfUrl String?   @map("ticket_pdf_url")
  issuedAt     DateTime  @default(now()) @map("issued_at")
  revoked      Boolean   @default(false)
  validUntil   DateTime? @map("valid_until")
  
  // Check-in/out tracking
  scannedAt    DateTime? @map("scanned_at")        // Legacy: first scan time
  checkedInAt  DateTime? @map("checked_in_at")     // Check-in timestamp
  checkedOutAt DateTime? @map("checked_out_at")    // Check-out timestamp  
  checkedInBy  String?   @map("checked_in_by")     // User ID who checked in
  
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@map("tickets")
}

model Waitlist {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  email     String
  name      String
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("waitlists")
  @@index([eventId, email])
}

model DiscountCode {
  id          String       @id @default(uuid())
  eventId     String       @map("event_id")
  code        String
  type        DiscountType @default(PERCENTAGE)
  amount      Int          // Percentage (e.g. 10 for 10%) or Amount in cents
  maxUses     Int?         @map("max_uses")
  usedCount   Int          @default(0) @map("used_count")
  validFrom   DateTime?    @map("valid_from")
  validUntil  DateTime?    @map("valid_until")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([eventId, code])
  @@map("discount_codes")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Review {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  userId      String   @map("user_id")
  rating      Int      // 1-5
  comment     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId]) // One review per user per event
  @@map("reviews")
}

// ============================================
// EVENT POLLS
// ============================================

model Poll {
  id          String       @id @default(uuid())
  eventId     String       @map("event_id")
  question    String
  description String?      @db.Text
  isActive    Boolean      @default(true) @map("is_active")
  allowMultiple Boolean    @default(false) @map("allow_multiple")
  endsAt      DateTime?    @map("ends_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  options     PollOption[]
  
  @@map("polls")
}

model PollOption {
  id        String     @id @default(uuid())
  pollId    String     @map("poll_id")
  text      String
  order     Int        @default(0)
  
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]
  
  @@map("poll_options")
}

model PollVote {
  id           String      @id @default(uuid())
  optionId     String      @map("option_id")
  voterEmail   String      @map("voter_email")
  createdAt    DateTime    @default(now()) @map("created_at")
  
  option       PollOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)
  
  @@unique([optionId, voterEmail]) // One vote per option per email
  @@map("poll_votes")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id          String   @id @default(uuid())
  eventId     String?  @map("event_id")
  type        String   // poll_created, event_reminder, waitlist_available
  title       String
  message     String   @db.Text
  recipientEmails String[] @map("recipient_emails")
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@map("notifications")
}

// ============================================
// TEAM MANAGEMENT
// ============================================

model TeamMember {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  email       String
  name        String?
  role        TeamRole @default(STAFF)
  invitedAt   DateTime @default(now()) @map("invited_at")
  acceptedAt  DateTime? @map("accepted_at")
  
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@unique([eventId, email])
  @@map("team_members")
}

enum TeamRole {
  SUPER_MANAGER // Full access including forms, financials
  MANAGER       // Edit event + check-in + analytics
  SCANNER       // Check-in only
  STAFF         // View only
}

// ============================================
// PUSH NOTIFICATIONS
// ============================================

model PushSubscription {
  id           String   @id @default(uuid())
  endpoint     String   @unique
  keys         Json
  userEmail    String?  @map("user_email")
  createdAt    DateTime @default(now()) @map("created_at")
  
  @@map("push_subscriptions")
}

// ============================================
// TICKET TIERS
// ============================================

model TicketTier {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  name        String   // "VIP", "Standard", "Early Bird"
  description String?  @db.Text
  priceCents  Int      @map("price_cents")
  capacity    Int?     // null = unlimited
  soldCount   Int      @default(0) @map("sold_count")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@map("ticket_tiers")
}

// ============================================
// SPEAKERS
// ============================================

model Speaker {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  name        String
  title       String?  // "CEO at Company"
  bio         String?  @db.Text
  photoUrl    String?  @map("photo_url")
  linkedIn    String?  @map("linkedin")
  twitter     String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@map("speakers")
}

// ============================================
// EVENT REMINDERS
// ============================================

model EventReminder {
  id               String    @id @default(uuid())
  eventId          String    @map("event_id")
  hoursBeforeEvent Int       @map("hours_before_event") // 24, 2, etc.
  subject          String
  message          String    @db.Text
  sentAt           DateTime? @map("sent_at")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  
  event            Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@map("event_reminders")
}
